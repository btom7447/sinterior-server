# ─── Server ────────────────────────────────────────────────────────────────
# Application environment: development | production | test
NODE_ENV=development

# Port the Express server will listen on
PORT=5000

# Frontend origin allowed by CORS (no trailing slash)
CLIENT_URL=http://localhost:3000

# ─── MongoDB ───────────────────────────────────────────────────────────────
# Full MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/sinterior?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_min_64_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_min_64_chars

# Access token lifetime (ms/s/m/h/d notation accepted by jsonwebtoken)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifetime — must match cookie maxAge
JWT_REFRESH_EXPIRES_IN=7d

# ─── Uploads ───────────────────────────────────────────────────────────────
# Directory (relative to server root) where uploads are stored
UPLOAD_DIR=uploads

# Maximum allowed upload size in megabytes
MAX_FILE_SIZE_MB=5

# ─── Email / SMTP ──────────────────────────────────────────────────────────
# Used for forgot-password emails. In development the reset token is returned
# directly in the API response so you don't need a real SMTP server.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=no-reply@sintherior.com
SMTP_PASS=your_smtp_password
EMAIL_FROM=Sintherior <no-reply@sintherior.com>

# ─── Rate Limits ───────────────────────────────────────────────────────────
# Window in milliseconds for rate limiting (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window for general routes
RATE_LIMIT_MAX=100

# Max requests per window for auth routes
AUTH_RATE_LIMIT_MAX=10
