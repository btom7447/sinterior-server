# ─── Server ────────────────────────────────────────────────────────────────
# Application environment: development | production | test
NODE_ENV=development

# Port the Express server will listen on
PORT=5000

# CORS allow-list for the frontend. Can be a single URL or a comma-separated
# list of origins. Do NOT use this for building email links — use CLIENT_APP_URL.
#   dev:  http://localhost:3000
#   prod: https://www.sintherior.com,https://sintherior.com
CLIENT_URL=http://localhost:3000

# Canonical public URL of the frontend. Single value only. Used to build
# links that users click (email verification, password reset, payment
# callback). Defaults to https://www.sintherior.com in production.
CLIENT_APP_URL=http://localhost:3000

# Public base URL of this server (used in email links, webhooks).
# In production (Railway) set this to https://api.sintherior.com.
# SERVER_URL=http://localhost:5000

# ─── MongoDB ───────────────────────────────────────────────────────────────
# Full MongoDB connection string (Atlas or local)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/sinterior?retryWrites=true&w=majority

# ─── JWT ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_min_64_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_min_64_chars

# Access token lifetime (ms/s/m/h/d notation accepted by jsonwebtoken)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token lifetime — must match cookie maxAge
JWT_REFRESH_EXPIRES_IN=7d

# ─── Uploads ───────────────────────────────────────────────────────────────
# Maximum allowed upload size in megabytes
MAX_FILE_SIZE_MB=5

# ─── Cloudinary ────────────────────────────────────────────────────────────
# Get from https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Rate Limits ───────────────────────────────────────────────────────────
# Window in milliseconds for rate limiting (default: 900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window for general routes
RATE_LIMIT_MAX=1000

# Max requests per window for auth routes
AUTH_RATE_LIMIT_MAX=50

# ─── Email (Resend) ────────────────────────────────────────────────────────
# Get your API key at https://resend.com → API Keys
# In development, leaving this empty makes sendEmail.js log instead of send.
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Sintherior <noreply@sintherior.com>

# ─── Payments (Paystack) ───────────────────────────────────────────────────
# Get your keys from Paystack Dashboard → Settings → API Keys & Webhooks
# Use TEST keys (sk_test_... / pk_test_...) in development
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public
